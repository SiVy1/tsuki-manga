generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RolePreset {
  READER
  EDITOR
  PUBLISHER
  ADMIN
}

enum TaxonomyType {
  GENRE
  TAG
}

enum SeriesVisibility {
  PUBLIC
  HIDDEN
}

enum ChapterStatus {
  DRAFT
  PUBLISHED
}

enum AssetKind {
  SERIES_COVER
  CHAPTER_PAGE
  INSTANCE_LOGO
  INSTANCE_FAVICON
}

enum AssetScope {
  PUBLIC
  DRAFT
}

enum StorageDriver {
  LOCAL
  S3
}

enum ReadingMode {
  WEBTOON
  VERTICAL
  RIGHT_TO_LEFT
}

enum ThemeMode {
  SYSTEM
  LIGHT
  DARK
}

enum RemovalRequestClaimantRole {
  COPYRIGHT_OWNER
  AUTHORIZED_AGENT
}

enum SeriesRemovalRequestStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_ACCEPTED
  RESOLVED_REJECTED
}

enum DiscordDeliveryStatus {
  SENT
  FAILED
  SKIPPED
}

model User {
  id                    String         @id @default(uuid()) @db.Uuid
  name                  String?
  email                 String?        @unique
  emailVerified         DateTime?
  image                 String?
  displayName           String?
  rolePreset            RolePreset     @default(READER)
  permissionBits        Int            @default(0)
  readingModePreference ReadingMode?
  themePreference       ThemeMode?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  accounts              Account[]
  sessions              Session[]
  createdSeries         Series[]       @relation("SeriesCreatedBy")
  updatedSeries         Series[]       @relation("SeriesUpdatedBy")
  createdChapters       Chapter[]      @relation("ChapterCreatedBy")
  updatedChapters       Chapter[]      @relation("ChapterUpdatedBy")
  createdAssets         Asset[]        @relation("AssetCreatedBy")
  savedSeries           SavedSeries[]
  authoredComments      Comment[]      @relation("CommentAuthor")
  deletedComments       Comment[]      @relation("CommentDeletedBy")
  commentReports        CommentReport[] @relation("CommentReportAuthor")
  resolvedCommentReports CommentReport[] @relation("CommentReportResolver")
  reviewedRemovalRequests SeriesRemovalRequest[] @relation("SeriesRemovalRequestReviewer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model InstanceSettings {
  id               String       @id @default(uuid()) @db.Uuid
  groupName        String
  groupDescription String?
  siteTitle        String
  siteDescription  String
  keywords         String[]
  logoAssetId      String?      @unique @db.Uuid
  faviconAssetId   String?      @unique @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  logoAsset        Asset?       @relation("InstanceLogoAsset", fields: [logoAssetId], references: [id], onDelete: SetNull)
  faviconAsset     Asset?       @relation("InstanceFaviconAsset", fields: [faviconAssetId], references: [id], onDelete: SetNull)
  socialLinks      SocialLink[]
  discordConfig    DiscordIntegrationConfig?
}

model SocialLink {
  id                 String           @id @default(uuid()) @db.Uuid
  instanceSettingsId String           @db.Uuid
  label              String
  url                String
  iconType           String?
  iconSvg            String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  instanceSettings InstanceSettings @relation(fields: [instanceSettingsId], references: [id], onDelete: Cascade)
}

model TaxonomyTerm {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  slug      String        @unique
  type      TaxonomyType
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  series    Series[]
}

model Series {
  id               String           @id @default(uuid()) @db.Uuid
  title            String
  slug             String           @unique
  descriptionShort String?
  descriptionLong  String?
  coverAssetId     String?          @unique @db.Uuid
  visibility       SeriesVisibility @default(PUBLIC)
  createdById      String           @db.Uuid
  updatedById      String           @db.Uuid
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  coverAsset       Asset?           @relation("SeriesCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  createdBy        User             @relation("SeriesCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy        User             @relation("SeriesUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  chapters         Chapter[]
  slugHistory      SeriesSlugHistory[]
  taxonomyTerms    TaxonomyTerm[]
  savedByUsers     SavedSeries[]
  removalRequests  SeriesRemovalRequest[]

  @@index([deletedAt])
  @@index([visibility, deletedAt])
}

model SavedSeries {
  userId    String   @db.Uuid
  seriesId  String   @db.Uuid
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@id([userId, seriesId])
  @@index([seriesId])
}

model SeriesSlugHistory {
  id        String   @id @default(uuid()) @db.Uuid
  seriesId  String   @db.Uuid
  slug      String   @unique
  createdAt DateTime @default(now())

  series Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

model Chapter {
  id          String        @id @default(uuid()) @db.Uuid
  seriesId    String        @db.Uuid
  slug        String        @unique
  number      Decimal       @db.Decimal(10, 2)
  label       String?
  title       String?
  status      ChapterStatus @default(DRAFT)
  publishedAt DateTime?
  createdById String        @db.Uuid
  updatedById String        @db.Uuid
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  series      Series        @relation(fields: [seriesId], references: [id], onDelete: Restrict)
  createdBy   User          @relation("ChapterCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User          @relation("ChapterUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  pages       ChapterPage[]
  slugHistory ChapterSlugHistory[]
  comments    Comment[]

  @@unique([seriesId, number, label])
  @@index([status, publishedAt, deletedAt])
  @@index([seriesId, deletedAt])
}

model ChapterSlugHistory {
  id        String   @id @default(uuid()) @db.Uuid
  chapterId String   @db.Uuid
  slug      String   @unique
  createdAt DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model ChapterPage {
  id        String   @id @default(uuid()) @db.Uuid
  chapterId String   @db.Uuid
  assetId   String   @unique @db.Uuid
  pageOrder Int
  width     Int
  height    Int
  createdAt DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([chapterId, pageOrder])
}

model Asset {
  id               String        @id @default(uuid()) @db.Uuid
  storageDriver    StorageDriver
  kind             AssetKind
  scope            AssetScope
  storageKey       String        @unique
  originalFilename String
  mimeType         String
  sizeBytes        BigInt
  width            Int?
  height           Int?
  createdById      String?       @db.Uuid
  createdAt        DateTime      @default(now())

  createdBy        User?         @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  chapterPage      ChapterPage?
  seriesCoverFor   Series?       @relation("SeriesCoverAsset")
  logoFor          InstanceSettings? @relation("InstanceLogoAsset")
  faviconFor       InstanceSettings? @relation("InstanceFaviconAsset")
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum CommentReportReason {
  SPAM
  HARASSMENT
  HATE
  SEXUAL_CONTENT
  VIOLENCE
  MISINFORMATION
  OTHER
}

enum CommentReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  REJECTED
}

model Comment {
  id           String        @id @default(uuid()) @db.Uuid
  chapterId    String        @db.Uuid
  authorId     String?       @db.Uuid
  parentId     String?       @db.Uuid
  body         String        @db.Text
  status       CommentStatus @default(VISIBLE)
  isEdited     Boolean       @default(false)
  editedAt     DateTime?
  deletedAt    DateTime?
  deletedById  String?       @db.Uuid
  deleteReason String?
  authorIpHash String?
  userAgent    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  chapter      Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  author       User?         @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  parent       Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]     @relation("CommentReplies")
  deletedBy    User?         @relation("CommentDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  reports      CommentReport[]

  @@index([chapterId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorId, createdAt])
  @@index([status, createdAt])
}

model CommentReport {
  id             String              @id @default(uuid()) @db.Uuid
  commentId      String              @db.Uuid
  authorId       String?             @db.Uuid
  reason         CommentReportReason
  details        String?             @db.Text
  status         CommentReportStatus @default(OPEN)
  resolvedAt     DateTime?
  resolvedById   String?             @db.Uuid
  resolutionNote String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  comment        Comment             @relation(fields: [commentId], references: [id], onDelete: Cascade)
  author         User?               @relation("CommentReportAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  resolvedBy     User?               @relation("CommentReportResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([commentId, createdAt])
  @@index([authorId, createdAt])
  @@index([status, createdAt])
  @@index([reason, createdAt])
}

model SeriesRemovalRequest {
  id                       String                     @id @default(uuid()) @db.Uuid
  seriesId                 String                     @db.Uuid
  claimantName             String
  organizationName         String?
  claimantEmail            String
  claimantRole             RemovalRequestClaimantRole
  workDescription          String                     @db.Text
  infringementExplanation  String                     @db.Text
  requestedAction          String
  additionalDetails        String?                    @db.Text
  electronicSignature      String
  goodFaithConfirmed       Boolean
  accuracyConfirmed        Boolean
  status                   SeriesRemovalRequestStatus @default(OPEN)
  reporterIpHash           String?
  userAgent                String?
  adminNote                String?                    @db.Text
  reviewedAt               DateTime?
  reviewedById             String?                    @db.Uuid
  resolutionNote           String?                    @db.Text
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  series                   Series                     @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  reviewedBy               User?                      @relation("SeriesRemovalRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([seriesId, createdAt])
  @@index([claimantEmail, createdAt])
  @@index([status, createdAt])
  @@index([reporterIpHash, createdAt])
}

model DiscordIntegrationConfig {
  id                       String                @id @default(uuid()) @db.Uuid
  instanceSettingsId       String                @unique @db.Uuid
  guildId                  String
  defaultLocale            String                @default("en")
  announcementChannelId    String?
  subscriptionChannelId    String?
  moderationChannelId      String?
  newSeriesChannelId       String?
  staffAlertRoleId         String?
  allowedManagerRoleIds    String[]
  subscriptionMessageIds   String[]
  chapterPublishedEnabled  Boolean               @default(true)
  seriesCreatedEnabled     Boolean               @default(true)
  commentReportedEnabled   Boolean               @default(true)
  copyrightReportedEnabled Boolean               @default(true)
  rolePrefix               String                @default("tsuki-series")
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  instanceSettings         InstanceSettings      @relation(fields: [instanceSettingsId], references: [id], onDelete: Cascade)
  deliveryLogs             DiscordDeliveryLog[]
}

model DiscordDeliveryLog {
  id                 String                 @id @default(uuid()) @db.Uuid
  discordConfigId    String                 @db.Uuid
  eventId            String                 @unique
  eventType          String
  status             DiscordDeliveryStatus
  message            String?
  targetChannelId    String?
  targetMessageId    String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  discordConfig      DiscordIntegrationConfig @relation(fields: [discordConfigId], references: [id], onDelete: Cascade)

  @@index([discordConfigId, createdAt])
  @@index([status, createdAt])
}
