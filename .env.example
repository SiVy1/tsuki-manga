NODE_ENV=development
APP_URL=http://localhost:3000
APP_TIMEZONE=UTC
AUTH_SECRET=replace-me-with-a-long-random-secret
AUTH_TRUST_HOST=false

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOOTSTRAP_ADMIN_ID=

ENABLE_TEST_AUTH=false
ALLOW_TEST_AUTH_IN_PRODUCTION=false
TEST_AUTH_SHARED_SECRET=

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tsuki_manga
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tsuki_manga_test

STORAGE_DRIVER=local

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=tsuki-manga
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000/tsuki-manga/public
