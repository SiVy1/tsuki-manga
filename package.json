{
  "name": "tsuki-manga",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit -p tsconfig.typecheck.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:integration:s3": "node scripts/run-s3-integration-tests.mjs",
    "test:e2e": "playwright test",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.1",
    "@aws-sdk/client-s3": "3.1022.0",
    "@prisma/adapter-pg": "7.6.0",
    "@prisma/client": "7.6.0",
    "next": "16.2.2",
    "next-auth": "5.0.0-beta.30",
    "pg": "8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "prisma": "7.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "4.1.2"
  }
}
